# FastAPI 版本服务配置
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=5001
FASTAPI_RELOAD=true

# CORS 白名单
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080

# ── 数据根目录（核心配置）────────────────────────────────────────────────────
# 所有持久化数据统一存储到此目录下，包括：
#   <RAG_DATA_ROOT>/db/          - SQLite 数据库（ragsystem.db、checkpoints.db）
#   <RAG_DATA_ROOT>/sessions/    - 会话数据
#   <RAG_DATA_ROOT>/memory/      - Agent 记忆
#   <RAG_DATA_ROOT>/uploads/     - 上传文件
#   <RAG_DATA_ROOT>/tasks/       - Task 追踪（JSON）
#   <RAG_DATA_ROOT>/config/      - 运行时配置（agent/mcp/provider/app）
#   <RAG_DATA_ROOT>/monitoring/  - 监控 trace
# 不配置则默认使用 ~/.ragsystem
# RAG_DATA_ROOT=C:/Users/<username>/.ragsystem

# ── 可选路径覆盖（一般不需要单独配置）────────────────────────────────────────
# UPLOAD_FOLDER=/path/to/uploads      # 覆盖上传目录（默认 DATA_ROOT/uploads）
# FRONTEND_DIST=/path/to/dist          # 前端构建产物目录
