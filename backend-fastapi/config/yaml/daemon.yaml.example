# 守护 Agent 系统配置 — 启动时自动初始化到 CONFIG_ROOT/daemon/daemon.yaml（已存在则不覆盖）
# 详细配置说明见 docs/architecture.md 守护系统章节。

enabled: false
default_session_ttl: 86400

agents:
  - team_name: default
    entry_agent:
    enabled: true
    session_id:
    heartbeat_interval: 30

    permissions:
      mode: standard
      auto_accept_patterns:
        - pattern_type: tool_name
          pattern_value: read_file
        - pattern_type: tool_name
          pattern_value: glob
        - pattern_type: tool_name
          pattern_value: grep
        - pattern_type: tool_name
          pattern_value: web_fetch
      skip_all_approvals: false

    platforms:
      feishu:
        enabled: false
        app_id: ""
        app_secret: ""
        token: ""
        encoding_aes_key: ""
        extra:
          receive_mode: long_connection

    cron_tasks: []
