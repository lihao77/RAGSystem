# 系统配置（与 config/models.py 一致）
# 可省略未修改项，缺省值由 models.py 补全。

vector_store:
  backend: sqlite_vec
  sqlite_vec:
    database_path: ""
    vector_dimension: 0
    distance_metric: cosine

llm:
  provider: ""
  provider_type: ""
  model_name: ""

embedding:
  provider: ""
  provider_type: ""
  model_name: ""
  batch_size: 100

system:
  max_content_length: 104857600

hooks:
  enabled: true
  workspace_trust:
    default: trusted
    rules: []

waiting:
  enabled: true
  default_poll_interval_seconds: 3.0
  max_poll_interval_seconds: 15.0
  idle_wait_timeout_seconds: 300.0
  local_cache_ttl_seconds: 600.0
  keepalive_interval_seconds: 240.0
  keepalive_grace_seconds: 30.0
  max_keepalive_rounds: 20
  allow_provider_keepalive: true
  hidden_keepalive_token_budget: 8
