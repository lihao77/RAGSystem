# 系统配置 — 启动时自动初始化到 CONFIG_ROOT/app/config.yaml（已存在则不覆盖）
# 可省略未修改项，缺省值由 config/models.py 补全。

vector_store:
  backend: sqlite_vec
  sqlite_vec:
    database_path: ""
    distance_metric: cosine

llm:
  provider_type: ""
  model_name: ""

embedding:
  provider_type: ""
  model_name: ""

system:
  max_content_length: 104857600

hooks:
  enabled: true

waiting:
  enabled: true

reflection:
  enabled: true
