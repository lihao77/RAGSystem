# MCP Server 配置 — 启动时自动初始化到 CONFIG_ROOT/mcp/mcp_servers.yaml（已存在则不覆盖）
# 也可在前端「MCP Server」页面管理。
#
# 支持三种传输方式：
#   stdio           — 通过标准输入/输出启动本地进程（最常用）
#   sse             — 通过 Server-Sent Events 连接远程服务
#   streamable_http — 通过 HTTP 流连接远程服务
#
# 示例：
#   servers:
#     filesystem:
#       display_name: 文件系统
#       transport: stdio
#       command: npx
#       args: ["-y", "@anthropic-ai/mcp-server-filesystem", "/tmp"]
#       env: {}
#       enabled: true
#       auto_connect: true
#       timeout: 30
#       risk_level: medium
#       requires_approval: false

servers: {}
