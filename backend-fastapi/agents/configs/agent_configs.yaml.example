# 智能体配置示例（与 AgentConfig 模型一致）
# 可选：不存在时由 AgentConfigManager 创建默认。复制为 agent_configs.yaml 后按需修改。
# llm_tiers 中 provider + provider_type 对应 providers.yaml 中的复合键（如 my_deepseek）

agents:
  qa_agent:
    agent_name: qa_agent
    display_name: "问答助手"
    description: "示例智能体"
    enabled: true
    default_entry: false

    # 多层级 LLM 配置（必配 default 层级作为主模型）
    llm_tiers:
      # default: 主模型（必配）
      default:
        provider: my
        provider_type: deepseek
        model_name: deepseek-chat
        temperature: 0.3
        max_completion_tokens: 4096      # 单次输出的最大 token 数
        max_context_tokens: 128000       # 模型支持的最大上下文窗口（128K）
        # extra_params:                  # 可选：provider-specific 字段透传
        #   thinking_budget_tokens: 8192
        #   reasoning_effort: medium

      # fast: 快速模型，用于简单任务（压缩、格式化、简单判断）
      fast:
        provider: my
        provider_type: deepseek
        model_name: deepseek-chat
        temperature: 0.2
        max_completion_tokens: 1000

      # powerful: 强力模型，用于复杂推理和困难任务（可选）
      # powerful:
      #   provider: my
      #   provider_type: openrouter
      #   model_name: anthropic/claude-3.5-sonnet
      #   temperature: 0.5
      #   max_completion_tokens: 8192

    tools:
      enabled_tools:
        - read_file
        - preview_data_structure
        - execute_code
    skills:
      enabled_skills: []
      auto_inject: true
    # MCP Server 配置（可选）
    # 需要先在运行时 MCP 配置中添加对应 Server（默认 ~/.ragsystem/config/mcp/mcp_servers.yaml）
    # mcp:
    #   enabled_servers:
    #     - filesystem      # 使用文件系统 MCP Server 的工具
    #     - brave_search    # 使用 Brave 搜索 MCP Server 的工具
    custom_params:
      type: orchestrator
      behavior:
        system_prompt: "你是问答助手。目标是直接、准确地完成任务。信息足够时直接回答；需要外部信息时再调用工具；缺少关键输入且无法自行补齐时，使用 request_user_input；不编造事实，不输出推理过程。"
        auto_execute_tools: true
        # max_context_tokens: 80000           # 可选：显式指定对话历史的上下文预算（覆盖自动计算）
        # 注意：这里的 max_context_tokens 是"对话历史预算"，不是模型原始 context window
        # compression_trigger_ratio: 0.85     # 可选：触发压缩的 token 比例（默认 0.85）
        # summarize_max_tokens: 300           # 可选：LLM 摘要的最大 token 数（默认 300）
        # preserve_recent_turns: 3            # 可选：保留最近 N 轮对话不压缩（默认 3）
        # 反思机制配置（可选覆盖，系统级默认已开启，见 config.yaml 的 reflection 段）
        # reflection:
        #   enabled: false                      # 关闭此 agent 的反思
        #   rounds_without_answer: 4            # 覆盖系统默认阈值

  # 系统级智能体，始终加载（与其他 Agent 不同，enabled 字段无效）
  orchestrator_agent:
    agent_name: orchestrator_agent
    display_name: Orchestrator Agent
    description: 动态智能体编排器，将 Agent 当作工具使用，通过 ReAct 模式实时决策
    enabled: true
    default_entry: true

    llm_tiers:
      default:
        provider: my
        provider_type: deepseek
        model_name: deepseek-chat
        temperature: 0.3
        max_completion_tokens: 4096
        max_context_tokens: 128000
        # extra_params:
        #   thinking_budget_tokens: 8192
        #   reasoning_effort: medium
      # fast:
      #   provider: my
      #   provider_type: deepseek
      #   model_name: deepseek-chat
      #   max_completion_tokens: 1000

    tools:
      enabled_tools: []                       # 留空；工具由运行时动态注入（invoke_agent_xxx 等）
    skills:
      enabled_skills: []
      auto_inject: false
    custom_params:
      type: orchestrator
      behavior:
        system_prompt: "你是主编排器。目标是用最少必要步骤完成任务：能直接回答就直接回答，能直接工具完成就不要额外委派，只有在需要专业能力时才调用子 Agent；缺少关键输入且无法补齐时使用 request_user_input；不编造事实，不输出推理过程。"
        compression_trigger_ratio: 0.85
        summarize_max_tokens: 300
        preserve_recent_turns: 3
        data_save_dir: ./static/temp_data
        # max_context_tokens: 100000          # 可选：显式指定上下文预算（覆盖自动计算）
        # 反思机制配置（可选覆盖，系统级默认已开启）
        # reflection:
        #   rounds_without_answer: 8          # orchestrator 可适当放宽轮次阈值
