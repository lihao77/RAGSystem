# Model Adapter Provider 配置 — 启动时自动初始化到 CONFIG_ROOT/model_adapter/providers.yaml（已存在则不覆盖）
# 填入 API key 后即可使用对话/向量等能力；也可在前端「模型适配器」页面添加。
#
# 格式说明：
#   顶层键为复合键 {name}_{provider_type}，如 my_deepseek、my_openrouter
#   api_key 支持 ${ENV_VAR} 从环境变量读取
#   model_map 支持字符串或字符串数组；models 由 model_map 自动归一生成，不需要手动维护。
#
# 示例：
#   my_deepseek:
#     name: my
#     provider_type: deepseek
#     api_key: "${DEEPSEEK_API_KEY}"
#     api_endpoint: ""
#     max_completion_tokens: 4096
#     max_context_tokens: 128000
#     temperature: 0.7
#     timeout: 30
#     retry_attempts: 10
#     retry_delay: 1.0
#     retry_backoff_factor: 2.5
#     supports_function_calling: true
#     model_map:
#       chat: deepseek-chat
